{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/integration",
    "types": [
      "jasmine",
      "node"
    ]
  },
  "include": [
    "src/tests-integration/test.ts",
    "src/**/*.ts",
    "src/tests-integration/**/*.integration.test.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
