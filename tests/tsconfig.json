{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "dom"],
    "types": ["cypress", "node", "vitest"],
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["../src/app/core/*"],
      "@features/*": ["../src/app/features/*"],
      "@shared/*": ["../src/app/shared/*"]
    }
  },
  "include": ["**/*.ts", "**/*.js"]
}
